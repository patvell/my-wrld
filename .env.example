# libSQL / Turso connection.
# For local development you can use a local SQLite file:
#   TURSO_DATABASE_URL=file:my-wrld.db
#   TURSO_AUTH_TOKEN=local-dev-token
# For a remote Turso database, use the libsql:// URL and a real auth token.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: FlightAware AeroAPI key. Enables flight lookup/autofill in the Add
# Trip modal and live status on active boarding passes. The app works without it
# (those features are simply hidden). Get a key from the AeroAPI portal.
FLIGHTAWARE_API_KEY=
